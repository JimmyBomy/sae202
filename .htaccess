# --- En-têtes de sécurité ---
<IfModule mod_headers.c>
  Header always set X-Content-Type-Options "nosniff"
  Header always set X-Frame-Options "SAMEORIGIN"
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>

# --- Cache navigateur (éco-conception : moins de requêtes répétées) ---
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType image/jpeg  "access plus 1 month"
  ExpiresByType image/png   "access plus 1 month"
  ExpiresByType image/webp  "access plus 1 month"
  ExpiresByType font/woff2  "access plus 1 year"
  ExpiresByType text/css    "access plus 1 week"
</IfModule>

# Toutes les URL qui ne correspondent pas à un fichier/dossier réel
# sont redirigées vers index.php (front controller MVC).
RewriteEngine On

RewriteRule ^gestion/?(.*)$ admin/$1 [L]

# Ne pas réécrire les fichiers et dossiers existants (css, images, etc.)
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# Tout le reste -> index.php
RewriteRule ^ index.php [L]
